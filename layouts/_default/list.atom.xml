{{ printf `<?xml version="1.0" encoding="utf-8"?>` | safeHTML }}
<feed xmlns="http://www.w3.org/2005/Atom"{{ with site.LanguageCode }} xml:lang="{{ . }}"{{ end }}>
  {{ printf `<title type="html"><![CDATA[%s]]></title>` site.Title | safeHTML }}
  {{ printf `<subtitle type="html"><![CDATA[%s]]></subtitle>` site.Params.description | safeHTML }}
  {{ with .OutputFormats.Get "atom" }}
    {{ printf `<link href=%q rel=%q type=%q title=%q />` .Permalink "self" .MediaType.Type site.Title | safeHTML }}
  {{ end }}
  {{ with .OutputFormats.Get "html" }}
    {{ printf `<link href=%q rel=%q type=%q title=%q />` .Permalink "alternate" .MediaType.Type site.Title | safeHTML }}
  {{ end }}
  <updated>{{ now.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</updated>
  {{ with site.Copyright }}
    <rights>{{ . | plainify }}</rights>
  {{- end }}
  {{ with site.Params.Author.name -}}
    <author>
      <name>{{ . }}</name>
      {{ with site.Params.Author.email }}
        <email>{{ . }}</email>
      {{ end -}}
    </author>
  {{- end }}
  {{ with site.Params.id }}
    <id>{{ . | plainify }}</id>
  {{ else }}
    <id>{{ .Permalink }}</id>
  {{ end }}
  {{- $feed_sections := site.Params.feedSections | default site.Params.mainSections -}}
  {{- $pages := where .RegularPages "Type" "in" $feed_sections -}}
  {{- if (eq .Kind "home") -}}
    {{- $pages = where site.RegularPages "Type" "in" $feed_sections -}}
  {{- end -}}
  {{- range $pages }}
    {{ $page := . }}
    <entry>
      {{ printf `<title type="html"><![CDATA[%s]]></title>` .Title | safeHTML }}
      <link href="{{ .Permalink }}" rel="alternate" type="text/html" />
      {{ with .Params.id }}
        <id>{{ . | plainify }}</id>
      {{ else }}
        <id>{{ .Permalink }}</id>
      {{ end }}
      {{ with .Site.Params.Author.name -}}
        <author>
          <name>{{ . }}</name>
        </author>
      {{- end }}
      <published>{{ .PublishDate.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</published>
      <updated>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</updated>
      {{ if ne .Summary .Content }}
        {{ printf `<summary type="html"><![CDATA[%s]]></summary>` .Summary | safeHTML }}
      {{ end }}
      {{ printf `<content type="html"><![CDATA[%s]]></content>` .Content | safeHTML }}
      {{ range $taxonomy, $terms := site.Taxonomies }}
        {{ with $page.Param $taxonomy }}
          {{ $entries := . }}
          {{ range $entries }}
            {{ printf `<category scheme="%s%s" term=%q label=%q />` site.BaseURL ($taxonomy | urlize) (. | urlize) .  | safeHTML }}
          {{ end }}
        {{ end }}
      {{ end }}
    </entry>
  {{ end }}
</feed>
